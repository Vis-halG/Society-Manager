rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    match /profile-images/{societyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 5 * 1024 * 1024;
    }

    match /notice-attachments/{societyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 15 * 1024 * 1024;
    }

    match /complaint-images/{societyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 10 * 1024 * 1024;
    }

    match /chat-images/{chatRoomId}/{fileName} {
      allow read, write: if isSignedIn() && request.resource.size < 10 * 1024 * 1024;
    }

    match /event-banners/{societyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 10 * 1024 * 1024;
    }

    match /event-gallery/{societyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 10 * 1024 * 1024;
    }

    match /documents/{societyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
