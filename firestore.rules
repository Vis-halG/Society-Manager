rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return isSignedIn() ? userDoc().role : null;
    }

    function societyId() {
      return isSignedIn() ? userDoc().societyId : null;
    }

    function isApproved() {
      return isSignedIn() && userDoc().approvalStatus == 'approved';
    }

    function isSuperAdmin() {
      return isSignedIn() && role() == 'super_admin';
    }

    function isAdminOf(sid) {
      return isSignedIn() && isApproved() && role() == 'admin' && societyId() == sid;
    }

    function isSecurityOf(sid) {
      return isSignedIn() && isApproved() && role() == 'security' && societyId() == sid;
    }

    function isMemberOf(sid) {
      return isSignedIn() && isApproved() && societyId() == sid;
    }

    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function isSelfProfileUpdate(userId) {
      return request.auth.uid == userId &&
        changedOnly([
          'fullName',
          'mobileNumber',
          'flatNumber',
          'wing',
          'profileImageUrl',
          'familyMembers',
          'fcmTokens',
          'isOnline',
          'lastSeen',
          'updatedAt'
        ]);
    }

    function isPollVoteAggregateUpdate() {
      return changedOnly(['options', 'totalVotes']) &&
        request.resource.data.totalVotes == resource.data.totalVotes + 1;
    }

    function pollForVote() {
      return get(/databases/$(database)/documents/polls/$(request.resource.data.pollId)).data;
    }

    function billForPayment() {
      return get(/databases/$(database)/documents/maintenanceBills/$(request.resource.data.billId)).data;
    }

    // ---------------- users ----------------
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() ||
                    (isApproved() && (role() == 'admin' || role() == 'security') &&
                     societyId() == resource.data.societyId));
      allow list: if isSuperAdmin() ||
                    (isApproved() && (role() == 'admin' || role() == 'security') &&
                     resource.data.societyId == societyId());
      allow create: if isSignedIn() && request.auth.uid == userId &&
                      request.resource.data.role == 'resident' &&
                      request.resource.data.approvalStatus == 'pending';
      allow update: if isSignedIn() && (
                      isSelfProfileUpdate(userId) ||
                      isSuperAdmin() ||
                      isAdminOf(resource.data.societyId)
                    );
      allow delete: if isSuperAdmin();
    }

    // ---------------- societies ----------------
    match /societies/{societyId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // ---------------- flats ----------------
    match /flats/{flatId} {
      allow read: if isMemberOf(resource.data.societyId) || isSuperAdmin();
      allow write: if isAdminOf(request.resource.data.societyId) || isSuperAdmin();
    }

    // ---------------- notices ----------------
    match /notices/{noticeId} {
      allow read: if isMemberOf(resource.data.societyId);
      allow create: if isAdminOf(request.resource.data.societyId);
      allow update, delete: if isAdminOf(resource.data.societyId);
    }

    // ---------------- complaints ----------------
    match /complaints/{complaintId} {
      allow read: if isSignedIn() && (
                    request.auth.uid == resource.data.raisedBy ||
                    isAdminOf(resource.data.societyId)
                  );
      allow create: if isMemberOf(request.resource.data.societyId) &&
                      request.resource.data.raisedBy == request.auth.uid;
      allow update: if isAdminOf(resource.data.societyId) ||
                      (request.auth.uid == resource.data.raisedBy &&
                       changedOnly(['title', 'description', 'category', 'images', 'updatedAt']));
      allow delete: if isAdminOf(resource.data.societyId);
    }

    // ---------------- complaintMessages ----------------
    match /complaintMessages/{messageId} {
      function parentComplaint() {
        return get(/databases/$(database)/documents/complaints/$(resource.data.complaintId)).data;
      }
      function parentComplaintOnCreate() {
        return get(/databases/$(database)/documents/complaints/$(request.resource.data.complaintId)).data;
      }
      allow read: if isSignedIn() && (
                    request.auth.uid == parentComplaint().raisedBy ||
                    isAdminOf(parentComplaint().societyId)
                  );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid && (
                      request.auth.uid == parentComplaintOnCreate().raisedBy ||
                      isAdminOf(parentComplaintOnCreate().societyId)
                    );
    }

    // ---------------- maintenanceBills ----------------
    match /maintenanceBills/{billId} {
      allow read: if isSignedIn() && (
                    request.auth.uid == resource.data.residentId ||
                    isAdminOf(resource.data.societyId)
                  );
      allow create: if isAdminOf(request.resource.data.societyId);
      allow update: if isAdminOf(resource.data.societyId) ||
                      (request.auth.uid == resource.data.residentId &&
                       resource.data.status != 'paid' &&
                       changedOnly(['status', 'paidAt', 'paymentId']) &&
                       request.resource.data.status == 'paid') ||
                      (request.auth.uid == resource.data.residentId &&
                       resource.data.status == 'unpaid' &&
                       changedOnly(['fineAmount', 'totalAmount', 'status']) &&
                       request.resource.data.status == 'overdue' &&
                       request.resource.data.fineAmount >= 0 &&
                       request.resource.data.totalAmount ==
                         resource.data.amount + request.resource.data.fineAmount);
      allow delete: if isAdminOf(resource.data.societyId);
    }

    // ---------------- payments ----------------
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
                    request.auth.uid == resource.data.residentId ||
                    isAdminOf(resource.data.societyId)
                  );
      allow create: if isSignedIn() &&
                    (
                      (request.auth.uid == request.resource.data.residentId &&
                       isMemberOf(request.resource.data.societyId)) ||
                      isAdminOf(request.resource.data.societyId)
                    ) &&
                    request.resource.data.residentId == billForPayment().residentId &&
                    request.resource.data.societyId == billForPayment().societyId &&
                    request.resource.data.amount == billForPayment().totalAmount;
    }

    // ---------------- visitors ----------------
    match /visitors/{visitorId} {
      allow read: if isSignedIn() && (
                    request.auth.uid == resource.data.hostUserId ||
                    isAdminOf(resource.data.societyId) ||
                    isSecurityOf(resource.data.societyId)
                  );
      allow create: if isSignedIn() && request.resource.data.hostUserId == request.auth.uid &&
                      isMemberOf(request.resource.data.societyId);
      allow update: if isAdminOf(resource.data.societyId) || isSecurityOf(resource.data.societyId);
      allow delete: if isAdminOf(resource.data.societyId);
    }

    // ---------------- parkingSlots ----------------
    match /parkingSlots/{slotId} {
      allow read: if isMemberOf(resource.data.societyId);
      allow create, delete: if isAdminOf(request.resource.data.societyId);
      allow update: if isAdminOf(resource.data.societyId);
    }

    // ---------------- vehicles ----------------
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn() && (
                    request.auth.uid == resource.data.ownerUserId ||
                    isAdminOf(resource.data.societyId)
                  );
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update: if isAdminOf(resource.data.societyId) ||
                      request.auth.uid == resource.data.ownerUserId;
      allow delete: if isAdminOf(resource.data.societyId) ||
                      request.auth.uid == resource.data.ownerUserId;
    }

    // ---------------- polls ----------------
    match /polls/{pollId} {
      allow read: if isMemberOf(resource.data.societyId);
      allow create: if isAdminOf(request.resource.data.societyId);
      allow update: if isAdminOf(resource.data.societyId) ||
                      (isMemberOf(resource.data.societyId) && isPollVoteAggregateUpdate());
      allow delete: if isAdminOf(resource.data.societyId);
    }

    // ---------------- votes ----------------
    match /votes/{voteId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() &&
                      request.resource.data.userId == request.auth.uid &&
                      voteId == request.resource.data.pollId + '_' + request.auth.uid &&
                      pollForVote().isActive == true &&
                      isMemberOf(pollForVote().societyId);
    }

    // ---------------- events ----------------
    match /events/{eventId} {
      allow read: if isMemberOf(resource.data.societyId);
      allow create: if isAdminOf(request.resource.data.societyId);
      allow update: if isAdminOf(resource.data.societyId) ||
                      (isMemberOf(resource.data.societyId) &&
                       changedOnly(['rsvps', 'gallery']));
      allow delete: if isAdminOf(resource.data.societyId);
    }

    // ---------------- documents ----------------
    match /documents/{documentId} {
      allow read: if isMemberOf(resource.data.societyId);
      allow create, delete: if isAdminOf(request.resource.data.societyId);
    }

    // ---------------- notifications ----------------
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && (
                      role() == 'admin' || role() == 'security' || role() == 'super_admin'
                    );
    }

    // ---------------- emergencyContacts ----------------
    match /emergencyContacts/{contactId} {
      allow read: if isMemberOf(resource.data.societyId);
      allow create, delete: if isAdminOf(request.resource.data.societyId);
    }

    // ---------------- chatRooms ----------------
    match /chatRooms/{chatRoomId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow update: if isSignedIn() &&
                     request.auth.uid in resource.data.participantIds &&
                     changedOnly(['lastMessage', 'lastMessageAt', 'unreadCount']);
      allow create: if isSignedIn() &&
                      request.auth.uid in request.resource.data.participantIds &&
                      isMemberOf(request.resource.data.societyId);
    }

    // ---------------- messages ----------------
    match /messages/{messageId} {
      function parentRoom() {
        return get(/databases/$(database)/documents/chatRooms/$(resource.data.chatRoomId)).data;
      }
      function parentRoomOnCreate() {
        return get(/databases/$(database)/documents/chatRooms/$(request.resource.data.chatRoomId)).data;
      }
      allow read: if isSignedIn() && request.auth.uid in parentRoom().participantIds;
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid &&
                      request.auth.uid in parentRoomOnCreate().participantIds;
      allow update: if isSignedIn() &&
                      request.auth.uid in parentRoom().participantIds &&
                      changedOnly(['readBy']);
    }
  }
}
