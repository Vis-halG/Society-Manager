{
  "expo": {
    "name": "Society Manager",
    "slug": "society-manager",
    "scheme": "societymanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.societymanager.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan visitor QR codes and capture complaint/profile photos.",
        "NSPhotoLibraryUsageDescription": "Used to attach images to complaints, notices, and your profile."
      }
    },
    "android": {
      "package": "com.societymanager.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Society Manager to access your camera to scan visitor QR codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Society Manager to access your photos to attach images.",
          "cameraPermission": "Allow Society Manager to use the camera to take photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1565C0"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
